{
	"geode": "5.5.3",
	"gd": {
		"win": "2.2081",
		"mac": "2.2081",
		"android": "2.2081",
		"ios": "2.2081"
	},
	"version": "v0.4.1-alpha",
	"id": "rgdps.level_tags",
	"name": "Level Tags",
	"developer": "RGDPS Team",
	"description": "A mod that adds tags to levels.",
	"dependencies": {
		"geode.node-ids": {
			"version": ">=v1.23.3",
			"required": true
		},
		"alphalaneous.happy_textures": {
			"version": ">=v2.1.11",
			"required": true
		}
	},
	"tags": [
		"interface",
		"utility",
		"online"
	],
	"resources": {
		"sprites": [
			"resources/*.png",
			"resources/tags/*.png"
		],
		"spritesheets": {
			"tags": [
				"resources/tags/*.png"
			]
		}
	},
	"links": {
		"source": "https://github.com/KampWskiR/Level-Tags",
		"community": "https://discord.gg/BwPG2n9F26"
	},
	"settings": {
		"customization": {
            "name": "Customization",
            "type": "title",
            "description": "These are settings that will customize your experience as best as possible."
        },
		"levelInfoShow": {
			"name": "LevelInfoLayer Tags",
			"description": "Enable tags displaying in LevelInfoLayer.",
			"type": "bool",
			"default": true
		},
		"pauseLayerShow": {
			"name": "Pause Screen Tags",
			"description": "Enable tags displaying in PauseLayer.",
			"type": "bool",
			"default": false
		},
		"hideRequest": {
			"name": "Hide Request Button",
			"type": "bool",
			"default": false
		},
		"tags-order": {
			"name": "Tag Order",
			"type": "string",
			"default": "style, theme, meta, gameplay",
			"one-of": ["style, theme, meta, gameplay","meta, gameplay, style, theme","gameplay, meta, style, theme"]
		},
		"hideStyle": {
			"name": "Hide Style Tags",
			"type": "bool",
			"default": false
		},
		"hideTheme": {
			"name": "Hide Theme Tags",
			"type": "bool",
			"default": false
		},
		"hideMeta": {
			"name": "Hide Meta Tags",
			"type": "bool",
			"default": false
		},
		"hideGameplay": {
			"name": "Hide Gameplay Tags",
			"type": "bool",
			"default": false
		},
		"other": {
            "name": "Other",
            "type": "title"
        },
		"serverUrl": {
			"name": "Server Url",
			"type": "string",
			"default": "https://api.leveltagrgdpscc.theworkpc.com",
			"filter": "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ:/.?&=0123456789",
			"description": "The URL of the server that stores the tags."
		}
	}
}
